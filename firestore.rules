rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // ===============================================================
    // Helper Functions
    // ===============================================================
    
    function isAuthenticated() {
      return request.auth != null;
    }
    
    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }
    
    function isAdmin() {
      return isAuthenticated() && (
        (request.auth.token.email == "abaalfadeel1@gmail.com" && request.auth.token.email_verified == true) ||
        (exists(/databases/$(database)/documents/users/$(request.auth.uid)) && 
         get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin')
      );
    }
    
    function hasOnlyAllowedFields(allowedFields) {
      return request.resource.data.keys().hasOnly(allowedFields);
    }

    function hasRequiredFields(requiredFields) {
      return request.resource.data.keys().hasAll(requiredFields);
    }

    // ===============================================================
    // Domain Validators
    // ===============================================================

    function isValidUser(data) {
      return data.uid is string && data.uid.size() > 0 &&
             data.email is string && data.email.size() > 0 &&
             data.displayName is string && data.displayName.size() > 0 && data.displayName.size() < 100 &&
             data.role in ['admin', 'client'] &&
             data.createdAt is timestamp &&
             (!('phoneNumber' in data) || (data.phoneNumber is string && data.phoneNumber.size() <= 20));
    }

    function isValidOrder(data) {
      return data.orderId is string && data.orderId.size() > 0 && data.orderId.size() < 50 &&
             data.userId is string && data.userId.size() > 0 &&
             data.serviceId is string && data.serviceId.size() > 0 &&
             data.serviceTitle is string && data.serviceTitle.size() > 0 && data.serviceTitle.size() < 100 &&
             data.projectType is string && data.projectType.size() > 0 && data.projectType.size() < 100 &&
             data.complexity is string && data.complexity.size() > 0 && data.complexity.size() < 50 &&
             data.extras is list && data.extras.size() <= 20 &&
             data.total is number && data.total >= 0 &&
             data.status in ['pending', 'paid', 'active', 'expired'] &&
             data.createdAt is timestamp &&
             data.clientEmail is string && data.clientEmail.size() > 0 &&
             data.clientPhone is string && data.clientPhone.size() > 0 && data.clientPhone.size() <= 20 &&
             (!('detailedDesc' in data) || (data.detailedDesc is string && data.detailedDesc.size() <= 2000)) &&
             (!('validFrom' in data) || data.validFrom is timestamp) &&
             (!('validUntil' in data) || data.validUntil is timestamp);
    }

    // ===============================================================
    // Rules
    // ===============================================================

    match /users/{userId} {
      allow read: if isOwner(userId) || isAdmin();
      allow create: if isAuthenticated() && 
                       isOwner(userId) && 
                       isValidUser(request.resource.data) && 
                       hasRequiredFields(['uid', 'email', 'displayName', 'role', 'createdAt']) &&
                       ((request.resource.data.role == 'client') || isAdmin());
      allow update: if isAuthenticated() && 
                       isValidUser(request.resource.data) && 
                       ((isOwner(userId) && request.resource.data.role == resource.data.role && request.resource.data.uid == resource.data.uid) || isAdmin());
      allow delete: if isAdmin();
    }

    match /orders/{orderId} {
      allow read: if isAuthenticated() && (resource.data.userId == request.auth.uid || isAdmin());
      allow create: if isAuthenticated() && 
                       request.resource.data.userId == request.auth.uid &&
                       isValidOrder(request.resource.data) &&
                       hasRequiredFields(['orderId', 'userId', 'serviceId', 'serviceTitle', 'projectType', 'complexity', 'extras', 'total', 'status', 'createdAt', 'clientEmail', 'clientPhone']);
      allow update: if isAdmin() && isValidOrder(request.resource.data);
      allow delete: if isAdmin();
    }
  }
}
